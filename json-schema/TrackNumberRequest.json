{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.17track.net/track/v1/schemas/TrackNumberRequest",
  "title": "TrackNumberRequest",
  "description": "Request body item for operations on an existing tracked number.",
  "type": "object",
  "required": ["number"],
  "properties": {
    "number": {
      "type": "string",
      "minLength": 5,
      "maxLength": 50,
      "pattern": "^[a-zA-Z0-9]{5,50}$",
      "description": "Tracking number (5-50 alphanumeric characters)",
      "example": "1Z999AA10123456784"
    }
  },
  "additionalProperties": false
}
